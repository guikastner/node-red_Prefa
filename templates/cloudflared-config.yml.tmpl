# Generated by OpenTofu. Maps the Node-RED container to a public hostname through the Cloudflare tunnel.
tunnel: ${tunnel_id}
credentials-file: ${credentials_file}

# Explicit DNS resolver to avoid internal DNS issues.
no-autoupdate: true

ingress:
%{ for inst in ingress ~}
  - hostname: ${inst.hostname}
    service: http://${inst.name}:1880
%{ endfor ~}
  - service: http_status:404

warp-routing:
  enabled: false

originRequest:
  noTLSVerify: true
